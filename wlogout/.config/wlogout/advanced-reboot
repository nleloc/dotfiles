{
    "label" : "archlinux",
    "action" : "systemctl reboot --boot-loader-entry=linux.conf --boot-loader-menu=1",
    "text" : "[R]Arch Linux",
    "keybind" : "r"
}
{
    "label" : "windows",
    "action" : "systemctl reboot --boot-loader-entry=auto-windows --boot-loader-menu=1",
    "text" : "[W]indows",
    "keybind" : "w"
}
{
    "label" : "more",
    "action" : "wlogout -p layer-shell -b1 -c10 -l ~/.config/wlogout/advanced-reboot-more",
    "text" : "More [O]ptions",
    "keybind" : "o"
}
