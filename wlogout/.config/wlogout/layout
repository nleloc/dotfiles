{
    "label" : "lock",
    "action" : "qs -c noctalia-shell ipc call lockScreen lock",
    "text" : "[L]ock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch 'hl.dsp.exit()'",
    "text" : "[E]xit Hypr",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "poweroff",
    "text" : "Sh[u]tdown",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "reboot",
    "text" : "[R]eboot",
    "keybind" : "r"
}
{
    "label" : "sleep",
    "action" : "qs -c noctalia-shell ipc call lockScreen lock && sleep 2 && loginctl suspend",
    "text" : "[S]leep",
    "keybind" : "s"
}
