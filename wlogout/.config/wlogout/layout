{
    "label" : "lock",
    "action" : "loginctl lock-session",
    "text" : "[L]ock",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "loginctl terminate-user",
    "text" : "[E]xit Hypr",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "poweroff",
    "text" : "Sh[u]tdown",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "wlogout -p layer-shell -b3 -c10 -l ~/.config/wlogout/advanced-reboot",
    "text" : "[R]eboot to",
    "keybind" : "r"
}
{
    "label" : "sleep",
    "action" : "loginctl lock-session && sleep 2 && systemctl sleep",
    "text" : "[S]leep",
    "keybind" : "s"
}
